config/

# 日志文件
*.log

# 临时文件
*.tmp
*.temp
*.bak
*.backup

# Python缓存
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# 开发环境
.env
.env.*

# 运行时数据
*.pid
*.seed
*.pid.lock

# IDE文件
.vscode/
.idea/
*.swp
*.swo
*~

# 系统文件
.DS_Store
Thumbs.db

