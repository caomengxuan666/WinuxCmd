#pragma once

namespace WinuxCmd {

// Version components
inline constexpr int VERSION_MAJOR = @VERSION_MAJOR@;
inline constexpr int VERSION_MINOR = @VERSION_MINOR@;
inline constexpr int VERSION_PATCH = @VERSION_PATCH@;

// Version string
inline constexpr const char* VERSION_STRING = "@VERSION_STRING@";

// Version as integer (MAJOR * 10000 + MINOR * 100 + PATCH)
inline constexpr int VERSION_NUMBER = VERSION_MAJOR * 10000 + VERSION_MINOR * 100 + VERSION_PATCH;

// Build information
inline constexpr const char* BUILD_TYPE = "@CMAKE_BUILD_TYPE@";
inline constexpr const char* BUILD_TIMESTAMP = "@BUILD_TIMESTAMP@";
inline constexpr const char* COMPILER_ID = "@CMAKE_CXX_COMPILER_ID@";
inline constexpr const char* COMPILER_VERSION = "@CMAKE_CXX_COMPILER_VERSION@";

} // namespace WinuxCmd
